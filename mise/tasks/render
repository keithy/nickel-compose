#!/usr/bin/env bash
#MISE description="Render config.ncl to compose.yml (use with -- config=path out=path)"
#MISE raw=true

# Find nickel-render.sh relative to this task file.
TASK_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$TASK_DIR/../.." && pwd)"
RENDER_SH="$ROOT/nickel-render.sh"

# Default config: ./config.ncl if present, else the bundled example.
if [[ -z "${config:-}" ]]; then
  if [[ -f "./config.ncl" ]]; then
    config="./config.ncl"
  else
    config="$ROOT/examples/podclaws/config.ncl"
  fi
fi

OUT="${out:-compose.yml}"

"$RENDER_SH" --config "$config" --out "$OUT"